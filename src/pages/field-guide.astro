---
import BaseLayout from "../layouts/BaseLayout.astro"
import Figure from "../components/Figure.astro"
import { quickFacts, topics } from "../data/site"

const classification = [
  { rank: "Kingdom", value: "Animalia" },
  { rank: "Class", value: "Mammalia" },
  { rank: "Order", value: "Carnivora" },
  { rank: "Family", value: "Felidae" },
  { rank: "Subfamily", value: "Felinae" },
  { rank: "Genus", value: "Otocolobus" },
  { rank: "Species", value: "O. manul" },
]

const didYouKnow = [
  "The manul is the only living species in the genus Otocolobus.",
  "It has round pupils, unlike the vertical slits of most small cats.",
  "Its low-set ears let it peer over rocks while staying hidden.",
  "It cannot run fast — survival depends on camouflage and stillness.",
  "It has been recorded living above 5,000 meters in elevation.",
  "Its fur is the densest of any cat relative to body size.",
]
---

<BaseLayout
  title="Field Guide — The Manul Atlas"
  description="A quick-reference field guide to the Pallas's cat: classification, measurements, and fast facts."
  image="/images/gallery-03.png"
>
  <header class="border-b border-line bg-ink text-parchment">
    <div class="mx-auto max-w-7xl px-5 py-20 lg:px-8 lg:py-28">
      <p class="eyebrow text-gold">Quick reference</p>
      <h1 class="mt-4 max-w-3xl text-balance font-serif text-4xl font-semibold leading-[1.05] tracking-tight sm:text-5xl lg:text-6xl">
        The manul at a glance
      </h1>
      <p class="mt-6 max-w-2xl text-pretty text-lg leading-relaxed text-parchment/80">
        Everything you need in one place — taxonomy, measurements, and the fast facts behind the steppe's most
        secretive cat.
      </p>
    </div>
  </header>

  <section class="mx-auto max-w-7xl px-5 py-16 lg:px-8">
    <div class="grid gap-12 lg:grid-cols-[1.1fr_0.9fr]">
      <div>
        <h2 class="mb-6 font-serif text-3xl font-semibold tracking-tight text-ink">Vital statistics</h2>
        <dl class="overflow-hidden rounded-[var(--radius-card)] border border-line">
          {quickFacts.map((f, i) => (
            <div class={`flex items-baseline justify-between gap-4 px-5 py-4 ${i % 2 === 0 ? "bg-parchment-2" : "bg-parchment"}`}>
              <dt class="text-sm uppercase tracking-[0.12em] text-muted">{f.label}</dt>
              <dd class="text-right font-serif text-lg font-medium text-ink">{f.value}</dd>
            </div>
          ))}
        </dl>
      </div>

      <div>
        <h2 class="mb-6 font-serif text-3xl font-semibold tracking-tight text-ink">Classification</h2>
        <dl class="overflow-hidden rounded-[var(--radius-card)] border border-line">
          {classification.map((c, i) => (
            <div class={`flex items-baseline justify-between gap-4 px-5 py-4 ${i % 2 === 0 ? "bg-parchment-2" : "bg-parchment"}`}>
              <dt class="text-sm uppercase tracking-[0.12em] text-muted">{c.rank}</dt>
              <dd class="text-right font-serif text-lg font-medium italic text-ink">{c.value}</dd>
            </div>
          ))}
        </dl>
        <div class="mt-6">
          <Figure
            src="/pallas-cat-website/images/gallery-03.png" 
            alt="Close-up of a Pallas's cat's eyes"
            caption="Otocolobus manul — Pallas (1776)."
            ratio="4/3"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="border-y border-line bg-parchment-2">
    <div class="mx-auto max-w-7xl px-5 py-16 lg:px-8">
      <h2 class="mb-8 font-serif text-3xl font-semibold tracking-tight text-ink">Did you know?</h2>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {didYouKnow.map((fact, i) => (
          <div class="reveal flex gap-4 rounded-[var(--radius-card)] border border-line bg-parchment p-5">
            <span class="font-serif text-2xl font-semibold text-gold">{String(i + 1).padStart(2, "0")}</span>
            <p class="text-sm leading-relaxed text-ink-soft">{fact}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-5 py-16 lg:px-8">
    <h2 class="mb-8 font-serif text-3xl font-semibold tracking-tight text-ink">Continue exploring</h2>
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {topics.map((t) => (
        <a href={t.href} class="reveal group overflow-hidden rounded-[var(--radius-card)] border border-line bg-parchment-2 transition hover:border-ink/30">
          <div class="img-zoom aspect-[16/10] overflow-hidden bg-stone">
            <img src={t.image} alt={t.title} loading="lazy" decoding="async" class="h-full w-full object-cover" />
          </div>
          <div class="p-5">
            <h3 class="font-serif text-xl font-semibold text-ink">{t.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-ink-soft">{t.blurb}</p>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
